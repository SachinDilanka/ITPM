# Copy to .env:  copy .env.example .env   (then edit MONGO_URI)

PORT=5000
NODE_ENV=development

# Required for auth (use a long random string in production)
JWT_SECRET=your_jwt_secret_min_32_chars

# Option A — local MongoDB
# MONGO_URI=mongodb://127.0.0.1:27017/itpm

# Option B — MongoDB Atlas (stable from any network)
# MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/itpm?retryWrites=true&w=majority
